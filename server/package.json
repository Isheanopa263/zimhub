{
  "name": "zimhub-server",
  "version": "1.0.0",
  "description": "ZimHub API Server",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js",
    "migrate:fresh": "node src/config/migrate.js && node src/config/seed.js",
    "db:reset": "node src/config/reset.js",
    "seed:posts": "node src/config/seed-posts.js",
    "start:prod": "NODE_ENV=production node src/cluster.js",
    "seed:notices": "node src/config/seed-notices.js",
    "test": "node tests/run-all.js",
    "test:quick": "node tests/run-all.js --quick"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
