# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:root123@localhost:5432/zimhub_db

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client
CLIENT_URL=http://localhost:5173

# Storage (Development - local, Production - R2)
STORAGE_TYPE=local
LOCAL_UPLOAD_PATH=./uploads

# Cloudflare R2 (Production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=